###############################################################################
# External spider crates (published on crates.io)
###############################################################################

# These are external spider ecosystem crates that are published
# They will be resolved via crate_universe from Cargo.lock

# spider_fingerprint - fingerprinting utilities
# spider_firewall - firewall detection (optional)
# spider_scraper - HTML scraping
# spider_transformations - content transformations
# spider_skills - skill definitions for agents
# chromey - Chrome DevTools Protocol implementation
# llm_models_spider - LLM model capabilities